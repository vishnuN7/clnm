PORT=5000
NODE_ENV=production

# Cloud SQL public IP or managed MySQL hostname
DB_HOST=your-cloud-sql-public-ip-or-hostname
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=cln_db

JWT_SECRET=replace-with-a-long-random-secret-generated-locally
JWT_EXPIRES_IN=8h

# Netlify frontend URL
ALLOWED_ORIGIN=https://your-site.netlify.app

ALLOWED_IP_PREFIX=
ALLOW_LOCALHOST=false

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=CLN <your-email@gmail.com>
