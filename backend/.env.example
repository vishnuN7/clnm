# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cln_db

# JWT Configuration - GENERATE STRONG SECRET IN PRODUCTION
# To generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=YOUR_STRONG_SECRET_HERE_MINIMUM_32_CHARACTERS
JWT_EXPIRES_IN=8h

# CORS Configuration - Set your production frontend domain(s)
# Example: ALLOWED_ORIGIN=https://your-site.netlify.app
ALLOWED_ORIGIN=http://localhost:5000

# Optional: used for password reset links. Set this to the same Netlify URL.
# Example: FRONTEND_BASE_URL=https://your-site.netlify.app
FRONTEND_BASE_URL=

# Office Network Restriction for Employee Logins
# Use IP prefix matching: "192.168." matches all 192.168.x.x IPs
# Use "192.168.1." to match only 192.168.1.x IPs
ALLOWED_IP_PREFIX=192.168.

# Set to "true" ONLY in development to allow localhost
# MUST be "false" in production
ALLOW_LOCALHOST=false

# Rate Limiting Configuration
# Time window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum login attempts per window
RATE_LIMIT_MAX_REQUESTS=5

# SMTP Configuration (Email - Password Reset)
# For Gmail: use smtp.gmail.com:587 with an App Password
# Steps to get Gmail App Password:
#   1. Enable 2-Step Verification on your Google Account
#   2. Go to myaccount.google.com > Security > App passwords
#   3. Select "Mail" and "Windows Computer" (or your device)
#   4. Copy the generated 16-character password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=Dixit Lending <your-email@gmail.com>
