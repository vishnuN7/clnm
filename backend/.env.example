# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Option A (recommended for Railway):
# MYSQL_URL=mysql://user:password@host:3306/database
# DATABASE_URL=mysql://user:password@host:3306/database

# Option B (separate fields):
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cln_db

# JWT Configuration - GENERATE STRONG SECRET IN PRODUCTION
# To generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=YOUR_STRONG_SECRET_HERE_MINIMUM_32_CHARACTERS
JWT_EXPIRES_IN=8h

# CORS Configuration - Set your production frontend domain(s)
# Example: ALLOWED_ORIGIN=https://your-site.netlify.app
ALLOWED_ORIGIN=http://localhost:5000

# Optional: used for password reset links. Set to your ACTUAL public domain in production.
# Example: FRONTEND_BASE_URL=https://dixitlendingsolution.in
FRONTEND_BASE_URL=

# Rate Limiting Configuration
# Time window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum login attempts per window
RATE_LIMIT_MAX_REQUESTS=5

# ─── Email Transport (choose ONE option) ───────────────────────────────────
# Option A: SMTP (Gmail or any SMTP provider) — recommended
# For Gmail, use an App Password (not your real password):
# Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=Your Name <your-email@gmail.com>

# Option B: Resend API (only used when SMTP_HOST is NOT set)
# Set a verified sender domain or address in Resend, then use its API key here.
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=Dixit Lending <no-reply@your-verified-domain.com>
RESEND_DEBUG=false
