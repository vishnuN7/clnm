# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cln_db

# JWT Configuration - GENERATE STRONG SECRET IN PRODUCTION
# To generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=YOUR_STRONG_SECRET_HERE_MINIMUM_32_CHARACTERS
JWT_EXPIRES_IN=8h

# CORS Configuration - Set your production domain
ALLOWED_ORIGIN=http://localhost:5000

# Office Network Restriction for Employee Logins
# Use IP prefix matching: "192.168." matches all 192.168.x.x IPs
# Use "192.168.1." to match only 192.168.1.x IPs
ALLOWED_IP_PREFIX=192.168.

# Set to "true" ONLY in development to allow localhost
# MUST be "false" in production
ALLOW_LOCALHOST=false

# Rate Limiting Configuration
# Time window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum login attempts per window
RATE_LIMIT_MAX_REQUESTS=5
